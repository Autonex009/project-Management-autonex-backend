# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use local SQLite (autonex.db)
# PostgreSQL example: postgresql://user:pass@localhost:5432/autonex
DATABASE_URL=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET_KEY=autonex-super-secret-key-change-in-production

# How long a password-reset link stays valid (minutes, default 15)
PASSWORD_RESET_EXPIRE_MINUTES=15

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used to build the reset-password link sent in emails.
# Falls back to the Origin header, then http://localhost:5173
RESET_PASSWORD_FRONTEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Brevo (free transactional email) ─────────────────────────────────────────
# Free tier: 300 emails/day — no credit card required.
# Uses Brevo's HTTP API (no extra Python packages needed).
#
# Setup:
#   1. Sign up at https://brevo.com
#   2. Go to Settings → API Keys → Generate a new API key
#   3. Go to Senders & IP → Senders → verify your sender email
#   4. Paste the API key and verified sender email below
#
BREVO_API_KEY=your-brevo-api-key-here

# Must match a verified sender in your Brevo account
MAIL_FROM=your-verified-sender@example.com
MAIL_FROM_NAME=Autonex AI

# ── Dev / Testing ─────────────────────────────────────────────────────────────
# Set to "true" to skip email sending and return the reset token directly
# in the /api/auth/forgot-password response body.
# NEVER enable this in production!
DEV_RETURN_RESET_TOKEN=false

# ── Slack integration ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=your_slack_bot_user_oauth_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# ── Salary encryption (PRODUCTION ONLY) ───────────────────────────────────────
# Encrypts employees.base_salary at rest. Set this ONLY on the production
# deployment (as a sensitive secret). Leave it UNSET in development — dev
# databases carry no real salaries, and without the key salary values are
# unreadable, which is the point.
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SALARY_KEY=

# ── Hiring Portal Integration ─────────────────────────────────────────────────
# Base URL of the hiring portal backend 
# The scheduler hits this every 12 hours to import newly hired candidates
HIRING_PORTAL_BASE_URL=http://127.0.0.1:8001

# API key to authenticate with the hiring portal , if any. Leave blank if the hiring portal does not require an API key.
HIRING_PORTAL_API_KEY=

# ── Encord Integration ────────────────────────────────────────────────────────
# SSH PRIVATE key contents (single line, use \n for newlines). Register the
# matching PUBLIC key in Encord. Alternatively set ENCORD_SSH_KEY_FILE to a path.
ENCORD_SSH_KEY=
ENCORD_SSH_KEY_FILE=
# Region domain. Leave blank for EU/global (api.encord.com); set to
# https://api.us.encord.com for US-hosted orgs.
ENCORD_DOMAIN=
# Days of history to pull on a backfill run (default 90).
ENCORD_BACKFILL_DAYS=90
# Set to 1 to also run the legacy 12h hiring-portal sync when the scheduler is on.
ENABLE_HIRING_SYNC=


